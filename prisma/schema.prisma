generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  superadmin
  admin
  staff
}

model User {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(staff)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model StoreSettings {
  id        Int      @id @default(1)
  storeName String   @default("Suvidha Store") @db.VarChar(255)
  address   String   @default("123, Suvidha Lane, Suvidha City") @db.VarChar(255)
  currency  String   @default("INR") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

model Product {
  id             String   @id @default(cuid())
  barcode        String?  @unique @db.VarChar(255)
  name           String   @db.VarChar(255)
  category       String   @default("general") @db.VarChar(100)
  stockQuantity  Int      @default(0) @map("stock_quantity")
  stockThreshold Int      @default(30) @map("stock_threshold")
  costPrice      Decimal  @map("cost_price") @db.Decimal(10, 2)
  sellingPrice   Decimal  @map("selling_price") @db.Decimal(10, 2)
  sales          Sale[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@index([name])
  @@map("products")
}

model Sale {
  id        Int      @id @default(autoincrement())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  quantity   Int
  totalPrice Decimal  @map("total_price") @db.Decimal(10, 2)
  totalCost  Decimal  @map("total_cost") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([createdAt])
  @@map("sales")
}

model Invoice {
  id      String   @id @default(cuid())
  student String
  date    DateTime @default(now())
  total   Decimal  @db.Decimal(10, 2)

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
